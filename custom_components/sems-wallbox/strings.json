{
  "title": "GoodWe SEMS Wallbox API",
  "exceptions": {
    "set_charge_mode_failed": {
      "message": "Failed to set charge mode to {option}. The previous mode has been restored."
    },
    "set_charge_power_failed": {
      "message": "Failed to set charge power to {value} kW. The previous value has been restored."
    }
  },
  "config": {
    "step": {
      "user": {
        "data": {
          "station_id": "[%key:common::config_flow::data::wallbox_serial_No%]",
          "username": "[%key:common::config_flow::data::username%]",
          "password": "[%key:common::config_flow::data::password%]",
          "scan_interval": "[%key:common::config_flow::data::scan_interval%]"
        }
      }
    },
    "error": {
      "cannot_connect": "[%key:common::config_flow::error::cannot_connect%]",
      "invalid_auth": "[%key:common::config_flow::error::invalid_auth%]",
      "unknown": "[%key:common::config_flow::error::unknown%]"
    },
    "abort": {
      "already_configured": "[%key:common::config_flow::abort::already_configured_device%]"
    }
  }
}